# OpenAI API key (only required for the single-LLM agent and the
# multi-agent LLM pipelines: scripts/run_phase{2,3,4}_*.py)
OPENAI_API_KEY=sk-...

# Optional: cap the budget per run as a safety net (USD).
# Leave commented to disable.
# OPENAI_MAX_COST_USD=10.0

# Optional: use a custom base URL (Azure, proxy, etc.).
# OPENAI_BASE_URL=https://api.openai.com/v1
